{
  "manifest_version": 3,
  "name": "Live",
  "version": "0.6.0",
  "description": "Import recipes and save articles to the Live app.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Live",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "identity",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://effervescent-malabi-e0af55.netlify.app/*",
    "http://localhost:4174/*",
    "http://localhost:8888/*",
    "https://noyocjcltrenwdovqrql.supabase.co/*",
    "https://www.nytimes.com/*",
    "https://www.economist.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}